# Nysus — environment template
# --------------------------------------------------------------------
# Copy to `.env.local` and fill in real values. NEVER commit .env.local.
# secrets.txt is also gitignored; treat it as staging only.
# --------------------------------------------------------------------

# --- Replicate (Seedance 2.0 video generation) ---
# Dedicated token scoped to this app. https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=

# --- OpenRouter (Claude via streaming SSE, with vision) ---
# Set a monthly spending cap in the OpenRouter dashboard.
OPENROUTER_API_KEY=

# --- Supabase (Postgres + Storage + Auth) ---
# Project URL is https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only; NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# --- App config ---
# Public URL the app is served from (used for magic-link redirect + Replicate webhook).
# Use http://localhost:3000 in dev, https://nysus.media in prod.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Shared secret for protected cron endpoints (webhook backup).
# Generate: `openssl rand -hex 32`
CRON_SECRET=

# Only this email can sign in (magic link is gated to this address).
ALLOWED_EMAIL=

# --- Behavior flags ---
# Must be `on_demand`. Prevents automatic Claude critique on clip completion.
CRITIQUE_MODE=on_demand
